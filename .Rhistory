res_MM <- LogBip(x = Methylation, method = "CG", maxit = 1000)
res_MM <- LogBip(x = Methylation, method = "CG", type=1)
cv_CG <- cv_LogBip(data = x$X, k = 0:5, method = "CG", type = 1)
